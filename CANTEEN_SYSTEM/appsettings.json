{
  "ConnectionStrings": {
    // Leave AzureSql empty for local SQLite usage.
    // Fill it with a real Azure SQL connection string to enable background cloud sync.
    "AzureSql": "",
    "LocalSqlite": "Data Source=canteen.db"
  },
  "CloudSync": {
    "IntervalSeconds": 15
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
